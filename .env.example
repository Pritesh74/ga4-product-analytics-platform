# ── Authentication ──────────────────────────────────────────────────────────
# BigQuery Sandbox uses Application Default Credentials (ADC).
# No service account key file required.
#
# Run once in your terminal to authenticate:
#   gcloud auth application-default login
#
# GOOGLE_APPLICATION_CREDENTIALS is NOT needed for the oauth dbt method.

# ── GCP Project ─────────────────────────────────────────────────────────────
# Your GCP project ID (found in console.cloud.google.com)
GCP_PROJECT_ID=your-gcp-project-id

# ── Streamlit App ────────────────────────────────────────────────────────────
# Project where dbt wrote the mart tables
APP_BQ_PROJECT=your-gcp-project-id

# Dataset names (must match dbt_project.yml +schema values)
APP_BQ_DATASET_MARTS=ga4_marts
APP_BQ_DATASET_EXPERIMENTS=ga4_experiments
